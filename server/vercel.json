{
    "version": 2,
    
    "crons": [
        {
            "path": "/api/v1/ingest/background",
            "schedule": "30 13 * * 1-5"
        }
    ],

    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.12"
            }
        }
    ],

    "routes": [
        {
            "src": "/(.*)",
            "dest": "main.py"
        }
    ]
}